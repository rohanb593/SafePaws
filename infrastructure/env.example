# Copy to app/.env — never commit .env to Git
# Supabase project credentials (find in Supabase dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for Edge Functions or server-side scripts (never expose in app)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Expo push notifications (if using Expo Push API in Edge Functions)
EXPO_ACCESS_TOKEN=your-expo-access-token-here
